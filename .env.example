APP_ENV=development
VITE_APP_ENV=development
APP_NAME=rag-service
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# Auth mode defaults to Clerk for realistic demos and auth validation.
# For local auth bypass, set both AUTH_MODE=local and VITE_AUTH_MODE=local.
# Local auth is only for local development; APP_ENV=production rejects AUTH_MODE=local.
AUTH_MODE=clerk
VITE_AUTH_MODE=clerk

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/rag_service

# Required in Clerk mode. Local auth mode skips Clerk initialization and token verification.
# Local auth signs the app in as Local Dev User / local-dev-user.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_JWT_PUBLIC_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rag-service-documents
S3_REGION=us-east-1
S3_SECURE=false

OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
RETRIEVAL_TOP_K=5
RETRIEVAL_EXPANDED_TOP_K=12
ENABLE_STRUCTURED_RETRIEVAL_PLAN=true
ENABLE_THINKING=false

UPLOAD_MAX_BYTES=26214400
INGESTION_MAX_RETRIES=3
INGESTION_POLL_INTERVAL_SECONDS=5
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_TOKENS=120
CHUNK_MAX_BATCH_SIZE=10
