APP_ENV=development
APP_NAME=rag-service
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/rag_service

VITE_CLERK_PUBLISHABLE_KEY=
CLERK_JWT_PUBLIC_KEY=
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rag-service-documents
S3_REGION=us-east-1
S3_SECURE=false

DASHSCOPE_API_KEY=replace-me
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
CHAT_MODEL=qwen3.6-plus
EMBEDDING_MODEL=text-embedding-v4
RETRIEVAL_TOP_K=5
ENABLE_THINKING=false

UPLOAD_MAX_BYTES=26214400
INGESTION_MAX_RETRIES=3
INGESTION_POLL_INTERVAL_SECONDS=5
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_TOKENS=120
CHUNK_MAX_BATCH_SIZE=10
